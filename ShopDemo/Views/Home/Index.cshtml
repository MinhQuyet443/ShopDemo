@if (!string.IsNullOrEmpty(Context.Request.Query["search"]))
{
    <p>
        🔍 Kết quả tìm kiếm:
        <b>@Context.Request.Query["search"]</b>
    </p>
}
@model List<ShopDemo.Models.SanPham>

<div class="container mt-4">
    <h2 class="text-center mb-4">🔥 SẢN PHẨM NỔI BẬT 🔥</h2>

    <div class="row">

        <!-- DANH MỤC -->
        <div class="col-md-3">
            <h4>Danh mục</h4>

            <ul class="list-group">
                <li class="list-group-item">
                    <a href="/">Tất cả</a>
                </li>

                @foreach (var dm in ViewBag.DanhMucs)
                {
                    <li class="list-group-item">
                        <a href="/Home/Index?madm=@dm.MaDM">
                            @dm.TenDM
                        </a>
                    </li>
                }
            </ul>
        </div>

        <!-- SẢN PHẨM -->
        <div class="col-md-9">

    <div class="row">
        @foreach (var sp in Model)
        {
            <div class="col-md-3 mb-4">
                <div class="card shadow-sm">

                    <img src="https://via.placeholder.com/200"
                         class="card-img-top"
                         style="height:200px; object-fit:cover;" />

                    <div class="card-body text-center">
                        <h5>@sp.TenSP</h5>

                        <p class="text-danger fw-bold">
                            @sp.GiaTien VNĐ
                        </p>

                                <button type="button"
                                        class="btn btn-primary w-100"
                                        onclick="addToCart(@sp.MaSP)">
                                    🛒 Thêm vào giỏ
                                </button>

                        <button class="btn btn-danger w-100 mt-2">
                            ⚡ Mua ngay
                        </button>
                    </div>

                </div>
            </div>
        }
    </div>
</div>
        <script>
            function addToCart(id) {
                fetch('/Cart/AddToCart?MaSP=' + id)
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            alert("✅ Đã thêm vào giỏ!");
                        } else {
                            alert("❌ Lỗi!");
                        }
                    })
                    .catch(err => console.log(err));
            }
        </script>
